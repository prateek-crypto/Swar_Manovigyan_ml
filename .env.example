# Copy to .env and fill in your values. Never commit .env.
# Optional: Azure OpenAI for therapeutic explanations and recommendation text.

# Azure OpenAI (optional – for AI-generated explanations in the app)
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
AZURE_OPENAI_API_KEY=YOUR_API_KEY
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Optional: Azure Speech (future – voice input / TTS for recommendations)
# AZURE_SPEECH_KEY=YOUR_SPEECH_KEY
# AZURE_SPEECH_REGION=eastus
